# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/fitnotion?retryWrites=true&w=majority

# JWT signing secret (use a long random string)
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# CORS origin of your frontend (comma-separated for multiple)
CLIENT_ORIGIN=http://localhost:8080,https://your-frontend.lovable.app

# Render sets PORT automatically; default 5000 locally
PORT=5000